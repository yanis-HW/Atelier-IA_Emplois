# Identifiants API France Travail (OAuth2 client_credentials)
# Copier ce fichier en .env puis remplir les valeurs. Ne JAMAIS commiter .env.

FT_CLIENT_ID=
FT_CLIENT_SECRET=

# Endpoint OAuth2 et scope : à confirmer sur la doc Swagger (francetravail.io)
# Valeurs de référence France Travail :
#   FT_TOKEN_URL=https://entreprise.francetravail.fr/connexion/oauth2/access_token?realm=/partenaire
#   FT_SCOPE=api_offresdemploiv2 o2dsoffre
FT_TOKEN_URL=
FT_SCOPE=
